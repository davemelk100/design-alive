# =============================================================================
# Themal - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Neon Postgres)
# https://console.neon.tech → your project → Connection Details → copy URI
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://...

# -----------------------------------------------------------------------------
# JWT Secret
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Used for signing auth tokens. See AUTHENTICATION_SETUP.md for details.
# -----------------------------------------------------------------------------
JWT_SECRET=...

# -----------------------------------------------------------------------------
# Base URL (local development)
# Change to your production URL when deploying.
# -----------------------------------------------------------------------------
URL=http://localhost:5173

# -----------------------------------------------------------------------------
# Google OAuth (used by Clerk for social login)
# https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Create an "OAuth client ID" of type "Web application"
# Add authorized redirect URIs for both local and production Clerk endpoints
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_REDIRECT_URI=http://localhost:8888/auth-login

# -----------------------------------------------------------------------------
# Stripe Billing
# https://dashboard.stripe.com/apikeys (toggle Test/Live mode in top-right)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_...            # Secret key (starts with sk_live_ or sk_test_)
STRIPE_CLIENT_SECRET=sk_live_...         # Same as STRIPE_SECRET_KEY (used by Netlify Functions)
STRIPE_WEBHOOK_SECRET=whsec_...          # Developers → Webhooks → signing secret

# Price IDs — found under Products → click product → Pricing section → copy ID
# https://dashboard.stripe.com/products
STRIPE_MONTHLY_PRICE_ID=price_...        # $9/mo recurring price
STRIPE_YEARLY_PRICE_ID=price_...         # $50/yr recurring price
STRIPE_TEST_PRICE_ID=price_...           # $0.50 one-time test price

# -----------------------------------------------------------------------------
# GitHub (for PR creation from the editor)
# https://github.com/settings/tokens → Generate new token (classic)
# Scopes needed: repo
# -----------------------------------------------------------------------------
GITHUB_TOKEN=ghp_...

# -----------------------------------------------------------------------------
# Clerk Authentication
# https://dashboard.clerk.com → your app → Configure → API Keys
# -----------------------------------------------------------------------------
VITE_CLERK_PUBLISHABLE_KEY=pk_live_...   # Frontend API key (starts with pk_live_ or pk_test_)
CLERK_SECRET_KEY=sk_live_...             # Backend secret key (starts with sk_live_ or sk_test_)

# -----------------------------------------------------------------------------
# Anthropic API (for AI theme generation)
# https://console.anthropic.com → API Keys → Create Key
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-...
