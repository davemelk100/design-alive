# =============================================================================
# Themal - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Clerk Authentication
# https://dashboard.clerk.com → your app → Configure → API Keys
# -----------------------------------------------------------------------------
VITE_CLERK_PUBLISHABLE_KEY=pk_live_...   # Frontend API key (starts with pk_live_ or pk_test_)
CLERK_SECRET_KEY=sk_live_...             # Backend secret key (starts with sk_live_ or sk_test_)

# -----------------------------------------------------------------------------
# Stripe Billing
# https://dashboard.stripe.com/apikeys (toggle Test/Live mode in top-right)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_...            # Secret key (starts with sk_live_ or sk_test_)
STRIPE_WEBHOOK_SECRET=whsec_...          # Webhook signing secret (Developers → Webhooks)

# Price IDs - found under Products → click product → Pricing section → copy ID
# https://dashboard.stripe.com/products
STRIPE_MONTHLY_PRICE_ID=price_...        # $9/mo recurring price
STRIPE_YEARLY_PRICE_ID=price_...         # $50/yr recurring price
STRIPE_TEST_PRICE_ID=price_...           # $0.50 one-time test price

# -----------------------------------------------------------------------------
# Google OAuth (used by Clerk, not directly by the app)
# https://console.cloud.google.com/apis/credentials
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# -----------------------------------------------------------------------------
# GitHub (for PR creation from the editor)
# https://github.com/settings/tokens → Generate new token (classic)
# Scopes needed: repo
# -----------------------------------------------------------------------------
GITHUB_TOKEN=ghp_...
PR_API_KEY=...                              # Shared secret sent as x-api-key header by the editor

# -----------------------------------------------------------------------------
# Base URL (local development)
# -----------------------------------------------------------------------------
URL=http://localhost:5173
