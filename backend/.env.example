# Backend Environment Variables
# Copy this file to .env and update with your values
# DO NOT commit .env to git - it contains sensitive information

# Database Configuration
# For production, use PostgreSQL:
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# For development, SQLite is fine:
DATABASE_URL=sqlite:///./content.db

# Security - CHANGE THESE IN PRODUCTION!
# Generate a secure secret key: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Admin Credentials - CHANGE IN PRODUCTION!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=davemelk@gmail.com

# CORS Origins
# Add your production frontend URL here (comma-separated)
# Example: https://yourdomain.com,https://www.yourdomain.com
# For development, localhost ports are included by default
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080
